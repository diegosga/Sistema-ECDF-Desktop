{
  "appId": "com.cecom.sistema",
  "productName": "Cadastro Cecom",
  
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "main.js",
    "setup.html",
    "setup.js",
    "preload.js",
    ".env",
    ".gitignore",
    "package.json",
    "cecom-sistema/**",
    "index.html"
    

],
  "extraResources": [
    "cecom-back-end/dist",
    "cecom-back-end/node_modules"
    
  ],
  "mac": {
    "target": ["dmg"]
  },
  "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
  "linux": {
    "target": ["AppImage"]
  }
}